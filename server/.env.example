# Bloxel server configuration
# Copy this file to .env and fill in your values

# HTTPS listen port
PORT=3000

# Internal WebSocket proxy port (localhost only, no need to expose)
WS_PORT=8888

# MySQL / MariaDB connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=bloxel
DB_PASSWORD=changeme
DB_NAME=bloxel
